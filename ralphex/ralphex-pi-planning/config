# ralphex config: pi executor (via opencode-go provider) -- planning profile
# usage: ralphex --config-dir ~/.config/ralphex-pi-planning --plan docs/plans/feature.md
# requires: pi CLI on PATH, jq on PATH, opencode-go provider already authenticated for pi
#
# kept at the same task_model as the default pi profile's original settings
# (before the default profile's task_model effort was lowered for day-to-day
# coding) -- this profile exists to keep plan quality unaffected by that change.

# route claude-slot phases (task, review) through pi via the vendored wrapper
claude_command = /opt/ralphex-profiles/pi-planning/scripts/pi-opencode-go.sh
claude_args =

# task execution model
task_model = deepseek-v4-flash

# use a different model for review phases than for task execution
# verified: `pi --provider opencode-go --model qwen3.7-plus --print` responds correctly
review_model = qwen3.7-plus

# no external (codex) review pass for this profile
external_review_tool = none
