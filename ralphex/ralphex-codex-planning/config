# ralphex config: codex executor (planning profile)
# usage: ralphex --config-dir ~/.config/ralphex-codex-planning --plan docs/plans/feature.md
# requires codex CLI >= 0.130.0
#
# kept at the same effort as the default codex profile's original settings
# (before the default profile's task effort was lowered for day-to-day
# coding) -- plan creation shares codex_reasoning_effort with task execution,
# so this profile exists to keep plan quality unaffected by that change.

# route plan/task/review/finalize phases through the codex CLI natively
executor = codex

# base codex model + effort used for plan creation and task execution.
# terra is the balanced GPT-5.6 tier: plan quality needs more headroom than
# the default profile's luna, without going all the way to sol.
codex_model = gpt-5.6-terra
codex_reasoning_effort = medium
# executor=codex defaults to danger-full-access in ralphex; force Codex's
# normal writable-workspace sandbox instead.
codex_sandbox = workspace-write

# use the flagship GPT-5.6 tier + higher reasoning effort for review phases
# than for task execution
review_model = gpt-5.6-sol:xhigh

# executor=codex already forces this to none, set explicitly for clarity
external_review_tool = none
