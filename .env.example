# Template for the .env file passed to `docker run --env-file .env`.
# Copy to .env, fill in real values, and keep .env out of version control
# (already excluded by .gitignore / .dockerignore). See README.md for the
# full description of each variable.

# --- git / GitHub -----------------------------------------------------------
GIT_USER_NAME=
GIT_USER_EMAIL=
GH_TOKEN=

# --- Hermes provider / model selection (non-secret) --------------------
# HERMES_MODEL_PROVIDER=
# HERMES_MODEL=

# --- LLM provider API keys (secrets; set whichever match your provider) --
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# --- approval mode / safety (headless operation) ------------------------
# HERMES_APPROVAL_MODE=smart
# HERMES_CRON_APPROVAL_MODE=deny
# HERMES_UNAUTHORIZED_DM_BEHAVIOR=pair
# HERMES_YOLO_MODE=0
# HERMES_TERMINAL_BACKEND=local
# HERMES_GATEWAY_NO_SUPERVISE=1

# --- ralphex --------------------------------------------------------------
# RALPHEX_DEFAULT_PROFILE=codex

# --- dashboard / Kanban (optional sidecar; off by default) ----------------
# HERMES_DASHBOARD_ENABLED=0
# HERMES_DASHBOARD_HOST=127.0.0.1
# HERMES_DASHBOARD_PORT=9119
# HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
# HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
